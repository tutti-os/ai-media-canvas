{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "ai-media-canvas",
  "version": "0.0.44",
  "name": "AI Canvas",
  "description": "Generate and organize AI images and videos on a canvas.",
  "icon": {
    "type": "asset",
    "src": "icon.svg"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/home"
  },
  "window": {
    "minimizeBehavior": "keep-mounted",
    "minWidth": 1024,
    "minHeight": 720
  },
  "launch": {
    "mode": "workspace-open"
  },
  "author": {
    "name": "Tutti"
  },
  "tags": ["generated", "local-first", "media-canvas", "local-debug"]
}
