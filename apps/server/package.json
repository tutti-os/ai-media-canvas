{
  "name": "@aimc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@aimc/shared": "workspace:*",
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.47.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/google-vertexai": "^2.1.31",
    "@langchain/langgraph": "1.3.3",
    "@langchain/openai": "^1.4.7",
    "@tutti-os/agent-acp-kit": "0.7.2",
    "agnes-ai-cli": "^0.1.4",
    "ajv": "^8.18.0",
    "deepagents": "^1.10.2",
    "fastify": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "langchain": "1.4.4",
    "openai": "^6.32.0",
    "undici": "^7.24.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aimc/config": "workspace:*",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "vitest": "^3.2.4",
    "ws": "^8.18.1"
  },
  "scripts": {
    "build": "node ../../scripts/validate-foundation-app.mjs build",
    "predev": "pnpm --filter @aimc/shared build",
    "dev": "node --watch --env-file=../../.env.local --import tsx ./src/server.ts & AIMC_WORKER_ID=w1 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & wait",
    "dev:server": "node --watch --env-file=../../.env.local --import tsx ./src/server.ts",
    "dev:worker": "node --watch --env-file=../../.env.local --import tsx ./src/worker.ts",
    "worker": "node --env-file=../../.env.local --import tsx ./src/worker.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
